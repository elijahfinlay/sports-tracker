<%- include('../partials/layout-start') %>

<div class="page-header">
  <div>
    <h1>Users</h1>
    <div class="subtitle">Dashboard accounts (admin can add, reset, deactivate)</div>
  </div>
  <a href="/settings" class="btn btn-secondary">Back to Settings</a>
</div>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'error' ? 'error' : 'success' %>"><%= flash.message %></div>
<% } %>

<div class="card">
  <h2>Add user</h2>
  <form method="POST" action="/users">
    <div class="field-row">
      <div class="field">
        <label>Username</label>
        <input type="text" name="username" autocomplete="off" required>
      </div>
      <div class="field">
        <label>Password (min 8)</label>
        <input type="password" name="password" autocomplete="new-password" required>
      </div>
      <div class="field" style="max-width:140px;">
        <label>Role</label>
        <select name="role">
          <option value="operator">Operator</option>
          <option value="admin">Admin</option>
        </select>
      </div>
    </div>
    <div class="btn-row">
      <button type="submit" class="btn btn-primary">Add user</button>
    </div>
  </form>
</div>

<div class="card">
  <h2>All users</h2>
  <table class="table">
    <thead>
      <tr>
        <th>Username</th>
        <th>Role</th>
        <th>Status</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td>
            <strong><%= u.username %></strong>
            <% if (u.id === user.id) { %><span class="tag tag-blue" style="margin-left:6px;">you</span><% } %>
          </td>
          <td>
            <form method="POST" action="/users/<%= u.id %>/role" style="display:inline;">
              <select name="role" onchange="this.form.submit()" style="padding:4px 8px; font-size:12px; border:1px solid var(--border-strong); border-radius:4px;">
                <option value="operator" <%= u.role === 'operator' ? 'selected' : '' %>>Operator</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
              </select>
            </form>
          </td>
          <td>
            <% if (u.is_active) { %>
              <span class="tag tag-green">active</span>
            <% } else { %>
              <span class="tag tag-gray">inactive</span>
            <% } %>
          </td>
          <td class="muted"><%= u.created_at %></td>
          <td style="text-align:right;">
            <form method="POST" action="/users/<%= u.id %>/reset" style="display:inline-flex; gap:6px; align-items:center;" onsubmit="return confirm('Reset password for <%= u.username %>?');">
              <input type="password" name="password" placeholder="new password" style="padding:5px 8px; font-size:12px; border:1px solid var(--border-strong); border-radius:4px; width:130px;">
              <button type="submit" class="btn btn-link" style="font-size:12px;">Reset</button>
            </form>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/users/<%= u.id %>/toggle" style="display:inline;" onsubmit="return confirm('<%= u.is_active ? "Deactivate" : "Reactivate" %> <%= u.username %>?');">
                <button type="submit" class="btn btn-link" style="font-size:12px; color: <%= u.is_active ? "var(--danger)" : "var(--accent-text)" %>;">
                  <%= u.is_active ? 'Deactivate' : 'Reactivate' %>
                </button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/layout-end') %>
