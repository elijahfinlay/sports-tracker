# Server
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string
NODE_ENV=development

# Database
DATABASE_PATH=./data/sports.db

# Encryption key for storing API credentials at rest (32 hex bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# File storage
UPLOAD_DIR=./uploads

# OSAA
OSAA_API_BASE_URL=https://www.osaa.org/api

# Twilio (Phase 4)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Retell AI (Phase 5)
RETELL_API_KEY=
RETELL_AGENT_ID=

# Anthropic (Phase 6)
ANTHROPIC_API_KEY=
